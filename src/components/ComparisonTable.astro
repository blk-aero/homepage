---
type Row = {
  feature: string;
  us: string;
  them: string;
};

type Props = {
  rows: Row[];
};

const { rows } = Astro.props as Props;
---

<section class="surface mt-6 overflow-hidden rounded-2xl p-4">
  <h2 class="mb-3 text-xl font-semibold">Nos vs Outros</h2>
  <div class="overflow-x-auto">
    <table aria-label="Nós vs Outros" class="w-full text-left text-sm">
      <thead>
        <tr>
          <th class="px-3 py-2">Critério</th>
          <th class="px-3 py-2">Nos</th>
          <th class="px-3 py-2">Outros</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class="border-t">
            <td class="px-3 py-2">{row.feature}</td>
            <td class="px-3 py-2">{row.us}</td>
            <td class="px-3 py-2">{row.them}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
