---
import { buildWhatsAppUrl } from "../lib/whatsapp";

type Props = {
  phone: string;
  email: string;
  service?: string | null;
  city?: string | null;
};

const { phone, email, service = null, city = null } = Astro.props as Props;
const cleanPhone = phone.replace(/\D/g, "");
const whatsappHref = buildWhatsAppUrl(cleanPhone, { service, city });
const payload = JSON.stringify({ service, city, page_path: Astro.url.pathname });
---

<div class="flex flex-wrap items-center gap-4" data-contact-links data-payload={payload}>
  <a data-track="whatsapp" href={whatsappHref} target="_blank" rel="noopener noreferrer" class="underline">{phone}</a>
  <a data-track="email" href={`mailto:${email}`} class="underline">{email}</a>
</div>

<script>
  const root = document.currentScript?.previousElementSibling;

  if (root instanceof HTMLElement) {
    const raw = root.dataset.payload;
    const basePayload = raw ? JSON.parse(raw) : {};

    root.querySelector('[data-track="whatsapp"]')?.addEventListener("click", () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: "whatsapp_click", ...basePayload });
    });

    root.querySelector('[data-track="email"]')?.addEventListener("click", () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: "email_click", ...basePayload });
    });
  }
</script>
