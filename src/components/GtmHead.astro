---
import { grantedConsentState } from "../lib/consent";
import { getSiteConfig } from "../lib/site-config";

const siteConfig = await getSiteConfig();
const envGtmId = (import.meta.env.PUBLIC_GTM_ID as string | undefined)?.trim();
const gtmId = envGtmId && envGtmId.length > 0 ? envGtmId : siteConfig.tracking.gtm_id;
const consentDefaults = grantedConsentState();
---

{gtmId && (
  <>
    <script define:vars={{ consentDefaults }}>
      window.dataLayer = window.dataLayer || [];
	function gtag(){dataLayer.push(arguments);}
	gtag('consent', 'default', consentDefaults);
    </script>
    <script async src={`https://www.googletagmanager.com/gtm.js?id=${gtmId}`}></script>
  </>
)}
