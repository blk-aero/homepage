---
import BrandIcon from "./BrandIcon.astro";
import { getWhatsAppNumber } from "../lib/contact";
import { buildWhatsAppUrl } from "../lib/whatsapp";

type Props = {
  content: {
    title: string;
    supportCopy: string;
    location: {
      label: string;
      placeholder: string;
      maxLength: number;
    };
    objectives: string[];
  };
  primaryCtaLabel: string;
};

const { content, primaryCtaLabel } = Astro.props as Props;
const number = getWhatsAppNumber();
const href = buildWhatsAppUrl(number, { ctaLocation: "final-cta" });
---

<section
  data-testid="section-final-cta"
  class="full-bleed mt-10 border-y border-primary-100 bg-primary-50 px-4 py-12 md:py-14"
>
  <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-[0.85fr_1.15fr] md:items-center">
    <div>
      <h2 class="text-3xl font-semibold leading-tight text-gray-950 md:text-4xl">{content.title}</h2>
      <p class="mt-4 text-base leading-7 text-gray-700">{content.supportCopy}</p>
    </div>
    <form
      class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_auto]"
      data-final-whatsapp-form
      data-whatsapp-number={number}
      data-cta-location="final-cta"
    >
      <label class="text-sm font-semibold text-gray-800">
        <span>{content.location.label}</span>
        <input
          class="mt-2 w-full rounded-lg border border-primary-200 bg-white px-3 py-3 text-sm font-normal text-gray-900 placeholder:text-gray-500 focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-100"
          name="location"
          maxlength={content.location.maxLength}
          placeholder={content.location.placeholder}
        />
      </label>
      <label class="text-sm font-semibold text-gray-800">
        <span>Objetivo</span>
        <select
          class="mt-2 w-full rounded-lg border border-primary-200 bg-white px-3 py-3 text-sm font-normal text-gray-900 focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-100"
          name="objective"
        >
          <option value="" selected disabled>Selecione o objetivo</option>
          {content.objectives.map((objective) => (
            <option value={objective}>{objective}</option>
          ))}
        </select>
      </label>
      <a
        class="btn-primary inline-flex items-center justify-center gap-2 rounded-lg px-5 py-3 text-sm font-semibold sm:self-end"
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        data-final-whatsapp-submit
      >
        <BrandIcon name="whatsapp" class="h-4 w-4" />
        <span>{primaryCtaLabel}</span>
      </a>
    </form>
  </div>
</section>
