---
import heroMonitoramentoInteligencia from "../assets/homepage/hero/blk-hero-e-monitoramento-inteligencia.webp";
import heroProjetoObra from "../assets/homepage/hero/blk-hero-e-projeto-obra.webp";
import heroRegularizacaoRural from "../assets/homepage/hero/blk-hero-e-regularizacao-rural.webp";
import heroRegularizacaoUrbana from "../assets/homepage/hero/blk-hero-e-regularizacao-urbana.webp";
import heroVolumetriaMedicao from "../assets/homepage/hero/blk-hero-e-volumetria-medicao.webp";
import { Image } from "astro:assets";
import WhatsAppCTA from "./WhatsAppCTA.astro";

const heroImages = {
  "projeto-obra": heroProjetoObra,
  "regularizacao-rural": heroRegularizacaoRural,
  "regularizacao-urbana": heroRegularizacaoUrbana,
  "volumetria-medicao": heroVolumetriaMedicao,
  "monitoramento-inteligencia": heroMonitoramentoInteligencia
};
type HeroImageId = keyof typeof heroImages;

type Props = {
  h1: string;
  subheadline: string;
  primaryCtaLabel: string;
  slides?: {
    title: string;
    imageId: HeroImageId;
    tag: string;
    panelLabel: string;
    panelTitle: string;
    description: string;
    alt: string;
    objectPosition: string;
    metrics: [string, string][];
  }[];
  secondaryCtaLabel?: string | null;
  secondaryCtaHref?: string | null;
};

const {
  h1,
  subheadline,
  primaryCtaLabel,
  slides = [],
  secondaryCtaLabel = null,
  secondaryCtaHref = null
} = Astro.props as Props;

const secondaryExternal = secondaryCtaHref ? /^https?:\/\//.test(secondaryCtaHref) : false;
---

<section data-testid="section-hero" class="surface overflow-hidden rounded-lg">
  <div data-testid="home-hero-main" class="grid gap-8 border-b border-gray-200 p-6 md:p-8 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:p-10 dark:border-gray-800">
    <div data-testid="home-hero-copy" class="min-w-0">
      <div class="mb-4 inline-flex rounded-full bg-lime-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-lime-900">
        Cinco caminhos, uma base técnica
      </div>
      <h1 class="text-3xl font-bold leading-tight md:text-5xl">{h1}</h1>
      <p id="summary" class="mt-5 text-base leading-7 text-gray-600 md:text-lg dark:text-gray-300">{subheadline}</p>

      <div class="mt-7 flex flex-wrap items-center gap-3">
        <WhatsAppCTA
          label={primaryCtaLabel}
          ctaLocation="home-hero"
          className="btn-primary inline-flex items-center gap-2 rounded-lg px-5 py-3 text-sm font-semibold"
        />
        {secondaryCtaLabel && secondaryCtaHref && (
          <a
            class="btn-secondary rounded-lg px-5 py-3 text-sm font-semibold"
            href={secondaryCtaHref}
            target={secondaryExternal ? "_blank" : undefined}
            rel={secondaryExternal ? "noopener noreferrer" : undefined}
          >
            {secondaryCtaLabel}
          </a>
        )}
      </div>
    </div>

    <div
      data-testid="home-hero-media"
      class="min-w-0 rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-800 dark:bg-gray-950"
    >
      <div
        id="home-hero-carousel"
        data-testid="home-hero-carousel"
        data-flowbite-hero-carousel
        data-carousel-interval="5200"
        class="rounded-lg border border-gray-300 bg-white p-4 dark:border-gray-800 dark:bg-gray-900"
      >
        <div class="relative min-h-[620px] overflow-hidden md:min-h-[520px]">
          {slides.map((slide, index) => (
            <article
              data-testid="home-hero-slide"
              data-carousel-slide
              data-carousel-item={index === 0 ? "active" : ""}
              data-active={index === 0 ? "true" : "false"}
              class:list={[
                "cluster-carousel-slide duration-700 ease-in-out",
                index === 0 ? "" : "hidden"
              ]}
              aria-hidden={index === 0 ? "false" : "true"}
            >
              <div class="relative overflow-hidden rounded-lg border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-950">
                <Image
                  data-testid="home-hero-image"
                  class="h-[390px] w-full object-cover"
                  src={heroImages[slide.imageId]}
                  alt={slide.alt}
                  loading={index === 0 ? "eager" : "lazy"}
                  fetchpriority={index === 0 ? "high" : "auto"}
                  decoding="async"
                  style={`object-position: ${slide.objectPosition};`}
                />
                <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.04)_0%,rgba(255,255,255,0)_38%,rgba(255,255,255,0.94)_100%)] dark:bg-[linear-gradient(180deg,rgba(3,7,18,0.04)_0%,rgba(3,7,18,0)_36%,rgba(3,7,18,0.92)_100%)]"></div>
                <div class="absolute left-4 top-4 rounded-full border border-lime-300 bg-white/90 px-3 py-1 font-mono text-xs font-semibold uppercase tracking-wide text-lime-900">
                  {slide.tag}
                </div>
                <div class="absolute inset-x-0 bottom-0 p-4">
                  <p class="text-sm font-semibold text-lime-800 dark:text-lime-300">{slide.title}</p>
                  <p class="font-mono text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">{slide.panelLabel}</p>
                  <h2 class="mt-1 text-lg font-semibold leading-snug text-gray-950 md:text-xl dark:text-white">
                    {slide.panelTitle}
                  </h2>
                  <p class="mt-2 max-w-2xl text-sm leading-6 text-gray-600 dark:text-gray-300">{slide.description}</p>
                </div>
              </div>

              <div class="mt-4 grid gap-3 text-sm md:grid-cols-3">
                {slide.metrics.map(([label, value]) => (
                  <div class="rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-800 dark:bg-gray-950">
                    <p class="font-mono text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">{label}</p>
                    <p class="mt-1 font-semibold text-gray-900 dark:text-gray-100">{value}</p>
                  </div>
                ))}
              </div>
            </article>
          ))}

          <div
            class="absolute left-4 top-12 z-40 flex translate-x-0 items-center gap-2 sm:left-1/2 sm:top-4 sm:-translate-x-1/2"
            role="tablist"
            aria-label="Serviços principais"
          >
            {slides.map((slide, index) => (
              <button
                type="button"
                data-carousel-dot
                data-carousel-slide-to={index}
                aria-label={`Mostrar ${slide.title}`}
                aria-current={index === 0 ? "true" : "false"}
                aria-pressed={index === 0 ? "true" : "false"}
                title={slide.title}
                class:list={[
                  "h-2.5 rounded-full border transition focus:outline-none focus:ring-2 focus:ring-lime-400 focus:ring-offset-2",
                  index === 0
                    ? "w-7 border-lime-500 bg-lime-500"
                    : "w-2.5 border-gray-300 bg-white/85 hover:bg-white"
                ]}
              >
                <span class="sr-only">{slide.title}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

</section>

<script>
  import Carousel from "flowbite/lib/esm/components/carousel";

  const ACTIVE_DOT_CLASSES = ["w-7", "border-lime-500", "bg-lime-500"];
  const INACTIVE_DOT_CLASSES = ["w-2.5", "border-gray-300", "bg-white/85"];

  document.querySelectorAll("[data-flowbite-hero-carousel]").forEach((root) => {
    if (!(root instanceof HTMLElement)) return;

    const slides = Array.from(root.querySelectorAll("[data-carousel-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-carousel-dot]"));
    const intervalMs = Number(root.dataset.carouselInterval || "2000");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let autoCycling = !reducedMotion;
    let timer = 0;

    function render(index) {
      slides.forEach((slide, slideIndex) => {
        if (!(slide instanceof HTMLElement)) return;
        const active = slideIndex === index;
        slide.setAttribute("aria-hidden", active ? "false" : "true");
        slide.setAttribute("data-active", active ? "true" : "false");
        slide.classList.toggle("hidden", !active);
      });
      dots.forEach((dot, dotIndex) => {
        const active = dotIndex === index;
        dot.setAttribute("aria-current", active ? "true" : "false");
        dot.setAttribute("aria-pressed", active ? "true" : "false");
        ACTIVE_DOT_CLASSES.forEach((className) => dot.classList.toggle(className, active));
        INACTIVE_DOT_CLASSES.forEach((className) => dot.classList.toggle(className, !active));
      });
    }

    const carousel = new Carousel(
      root,
      slides.map((slide, position) => ({ position, el: slide as HTMLElement })),
      {
        defaultPosition: 0,
        interval: intervalMs,
        indicators: {
          items: dots.map((dot, position) => ({ position, el: dot as HTMLElement })),
          activeClasses: ACTIVE_DOT_CLASSES.join(" "),
          inactiveClasses: INACTIVE_DOT_CLASSES.join(" ")
        },
        onChange: (instance) => {
          render(instance.getActiveItem().position);
        }
      },
      { id: `${root.id || "home-hero-carousel"}-instance`, override: true }
    );

    function stop() {
      window.clearInterval(timer);
      timer = 0;
    }

    function start() {
      if (!autoCycling || timer || slides.length < 2) return;
      timer = window.setInterval(() => {
        carousel.next();
      }, intervalMs);
    }

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        autoCycling = false;
        stop();
      });
    });

    root.addEventListener("mouseenter", () => {
      stop();
    });
    root.addEventListener("mouseleave", () => {
      start();
    });
    root.addEventListener("focusin", () => {
      stop();
    });
    root.addEventListener("focusout", () => {
      start();
    });

    render(0);
    start();
  });
</script>
