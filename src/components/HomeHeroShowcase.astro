---
import aconvapLogo from "../assets/brand/aconvap.png";
import heroCover from "../assets/brand/cover-drone-mountain-bw.webp";
import WhatsAppCTA from "./WhatsAppCTA.astro";

type Props = {
  h1: string;
  subheadline: string;
  primaryCtaLabel: string;
  primaryCtaHref: string;
  slides?: {
    title: string;
    tag: string;
    description: string;
    metric: string;
    alt: string;
  }[];
  secondaryCtaLabel?: string | null;
  secondaryCtaHref?: string | null;
};

const {
  h1,
  subheadline,
  primaryCtaLabel,
  slides = [],
  secondaryCtaLabel = null,
  secondaryCtaHref = null
} = Astro.props as Props;

const secondaryExternal = secondaryCtaHref ? /^https?:\/\//.test(secondaryCtaHref) : false;
const heroCoverSrc = typeof heroCover === "string" ? heroCover : heroCover.src;
const aconvapLogoSrc = typeof aconvapLogo === "string" ? aconvapLogo : aconvapLogo.src;
---

<section data-testid="section-hero" class="surface overflow-hidden rounded-2xl">
  <div data-testid="home-hero-main" class="grid gap-0 border-b border-gray-200 md:grid-cols-[minmax(0,1.22fr)_minmax(0,1fr)] dark:border-gray-800">
    <div data-testid="home-hero-copy" class="min-w-0 p-6 md:p-8">
      <div class="mb-2 inline-flex rounded-full px-3 py-1 text-xs font-semibold pill-accent">Decisao auditavel</div>
      <h1 class="text-3xl font-bold leading-tight md:text-5xl">{h1}</h1>
      <p id="summary" class="bluf-text mt-4 text-base md:text-lg">{subheadline}</p>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <WhatsAppCTA
          label={primaryCtaLabel}
          ctaLocation="home-hero"
          className="btn-primary rounded-lg px-5 py-3 text-sm font-semibold"
        />
        {secondaryCtaLabel && secondaryCtaHref && (
          <a
            class="btn-secondary rounded-lg px-5 py-3 text-sm font-semibold"
            href={secondaryCtaHref}
            target={secondaryExternal ? "_blank" : undefined}
            rel={secondaryExternal ? "noopener noreferrer" : undefined}
          >
            {secondaryCtaLabel}
          </a>
        )}
      </div>
    </div>

    <div
      data-testid="home-hero-media"
      data-carousel-interval="2000"
      class="relative min-h-72 border-t border-gray-200 md:min-h-full md:border-t-0 md:border-l dark:border-gray-800"
    >
      <img
        data-testid="home-hero-image"
        src={heroCoverSrc}
        alt="Operacao de drone em area montanhosa"
        class="h-full w-full object-cover object-center grayscale contrast-110"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-tr from-black/35 via-black/20 to-transparent"></div>
      <div
        data-testid="home-hero-carousel"
        class="absolute inset-x-4 bottom-4 rounded-xl bg-white/90 p-4 shadow-lg backdrop-blur dark:bg-gray-950/85"
      >
        <div class="grid">
          {slides.map((slide, index) => (
            <article
              data-testid="home-hero-slide"
              data-carousel-slide
              data-active={index === 0 ? "true" : "false"}
              class:list={[
                "col-start-1 row-start-1 transition-opacity",
                index === 0 ? "opacity-100" : "pointer-events-none opacity-0"
              ]}
              aria-hidden={index === 0 ? "false" : "true"}
            >
              <p class="text-xs font-semibold uppercase text-gray-600 dark:text-gray-400">
                {slide.tag}
              </p>
              <h2 class="mt-1 text-lg font-bold text-gray-950 dark:text-white">{slide.title}</h2>
              <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">{slide.description}</p>
              <p class="mt-3 text-xs font-semibold text-gray-900 dark:text-gray-100">
                {slide.metric}
              </p>
            </article>
          ))}
        </div>
        <div class="mt-4 flex gap-2" aria-label="Selecionar solução em destaque">
          {slides.map((slide, index) => (
            <button
              type="button"
              data-carousel-dot
              data-slide-index={index}
              aria-label={`Mostrar ${slide.title}`}
              aria-pressed={index === 0 ? "true" : "false"}
              class:list={[
                "h-2.5 w-8 rounded-full transition",
                index === 0 ? "bg-gray-950 dark:bg-white" : "bg-gray-300 dark:bg-gray-700"
              ]}
            />
          ))}
        </div>
      </div>
    </div>
  </div>

  <div data-testid="home-hero-brands" class="px-6 py-6 md:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-600 dark:text-gray-400">Parcerias de campo</p>
    <div class="mt-4 flex flex-wrap items-center gap-10">
      <a
        class="inline-flex transition hover:-translate-y-0.5"
        href="https://aconvap.com.br/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="ACONVAP"
      >
        <img
          data-testid="brand-aconvap"
          src={aconvapLogoSrc}
          alt="ACONVAP"
          class="h-8 w-auto grayscale opacity-70 transition hover:opacity-90"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
  </div>
</section>

<script>
  const ACTIVE_DOT_CLASSES = ["bg-gray-950", "dark:bg-white"];
  const INACTIVE_DOT_CLASSES = ["bg-gray-300", "dark:bg-gray-700"];

  document.querySelectorAll("[data-testid='home-hero-media'][data-carousel-interval]").forEach((root) => {
    if (!(root instanceof HTMLElement)) return;

    const slides = Array.from(root.querySelectorAll("[data-carousel-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-carousel-dot]"));
    const intervalMs = Number(root.dataset.carouselInterval || "2000");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let current = 0;
    let paused = false;
    let stopped = reducedMotion;
    let timer = 0;

    function render(index) {
      current = index;
      slides.forEach((slide, slideIndex) => {
        const active = slideIndex === current;
        slide.setAttribute("aria-hidden", active ? "false" : "true");
        slide.setAttribute("data-active", active ? "true" : "false");
        slide.classList.toggle("opacity-100", active);
        slide.classList.toggle("opacity-0", !active);
        slide.classList.toggle("pointer-events-none", !active);
      });
      dots.forEach((dot, dotIndex) => {
        const active = dotIndex === current;
        dot.setAttribute("aria-pressed", active ? "true" : "false");
        dot.classList.toggle(ACTIVE_DOT_CLASSES[0], active);
        dot.classList.toggle(ACTIVE_DOT_CLASSES[1], active);
        dot.classList.toggle(INACTIVE_DOT_CLASSES[0], !active);
        dot.classList.toggle(INACTIVE_DOT_CLASSES[1], !active);
      });
    }

    function advance() {
      if (stopped || paused || slides.length === 0) return;
      render((current + 1) % slides.length);
    }

    function start() {
      if (stopped || timer || slides.length < 2) return;
      timer = window.setInterval(advance, intervalMs);
    }

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        stopped = true;
        window.clearInterval(timer);
        timer = 0;
        render(Number((dot as HTMLElement).dataset.slideIndex || "0"));
      });
    });

    root.addEventListener("mouseenter", () => {
      paused = true;
    });
    root.addEventListener("mouseleave", () => {
      paused = false;
    });
    root.addEventListener("focusin", () => {
      paused = true;
    });
    root.addEventListener("focusout", () => {
      paused = false;
    });

    render(0);
    start();
  });
</script>
