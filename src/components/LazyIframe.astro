---
type Props = {
  src: string;
  title: string;
  height?: number | null;
};

const { src, title, height = 480 } = Astro.props as Props;
const boxId = `lazy-iframe-${Math.random().toString(36).slice(2, 9)}`;
---

<div id={boxId} class="surface overflow-hidden rounded-2xl">
  <button
    type="button"
    data-lazy-iframe
    data-src={src}
    data-title={title}
    data-height={String(height)}
    class="w-full px-4 py-8 text-sm font-semibold"
  >
    Carregar conteudo
  </button>
</div>

<script is:inline>
  document.querySelectorAll("[data-lazy-iframe]").forEach((node) => {
    const trigger = node;
    if (!(trigger instanceof HTMLButtonElement)) return;
    if (trigger.dataset.bound === "1") return;
    trigger.dataset.bound = "1";

    trigger.addEventListener("click", () => {
      const src = trigger.dataset.src;
      const title = trigger.dataset.title;
      const height = trigger.dataset.height || "480";
      if (!src || !title) return;
      const root = trigger.closest("div");
      if (!root) return;

      const iframe = document.createElement("iframe");
      iframe.src = src;
      iframe.title = title;
      iframe.loading = "lazy";
      iframe.className = "w-full";
      iframe.style.height = `${Number.parseInt(height, 10) || 480}px`;

      root.replaceChildren(iframe);
    });
  });
</script>
