---
type SchemaMeta = {
  canonicalUrl?: string;
  webpageId?: string;
  aboutId?: string | null;
  description?: string | null;
  uploadDate?: string | null;
  duration?: string | null;
  thumbnailUrl?: string | null;
  transcript?: string | null;
};

type Props = {
  videoId: string;
  title: string;
  schema?: SchemaMeta | null;
};

const { videoId, title, schema = null } = Astro.props as Props;
const placeholderId = `lite-yt-${videoId}`;
const thumbnail = schema?.thumbnailUrl ?? `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
const videoNodeId = schema?.canonicalUrl ? `${schema.canonicalUrl}#video-${videoId}` : null;
const videoJson =
  schema && schema.canonicalUrl && schema.webpageId
    ? {
        "@context": "https://schema.org",
        "@type": "VideoObject",
        "@id": videoNodeId,
        name: title,
        description: schema.description ?? title,
        uploadDate: schema.uploadDate ?? undefined,
        duration: schema.duration ?? undefined,
        thumbnailUrl: thumbnail,
        embedUrl: `https://www.youtube-nocookie.com/embed/${videoId}`,
        isPartOf: { "@id": schema.webpageId },
        about: schema.aboutId ? [{ "@id": schema.aboutId }] : undefined,
        transcript: schema.transcript ?? undefined
      }
    : null;
---

<div id={placeholderId} class="surface overflow-hidden rounded-2xl">
  <button
    type="button"
    class="group relative block w-full"
    data-lite-youtube
    data-video-id={videoId}
    data-target={placeholderId}
    aria-label={`Ver video ${title}`}
  >
    <img src={thumbnail} alt={`Thumbnail de ${title}`} class="aspect-video w-full object-cover" loading="lazy" />
    <span class="absolute inset-0 flex items-center justify-center bg-black/35 text-white">
      <span class="rounded-lg border border-white/60 px-4 py-2 text-sm font-semibold">Ver video</span>
    </span>
  </button>
</div>

{videoJson && <script type="application/ld+json" set:html={JSON.stringify(videoJson)}></script>}

<script is:inline>
  document.querySelectorAll("[data-lite-youtube]").forEach((node) => {
    const trigger = node;
    if (!(trigger instanceof HTMLButtonElement)) return;
    if (trigger.dataset.bound === "1") return;
    trigger.dataset.bound = "1";

    trigger.addEventListener("click", () => {
      const id = trigger.dataset.videoId;
      if (!id) return;
      const targetId = trigger.dataset.target;
      if (!targetId) return;
      const root = document.getElementById(targetId);
      if (!root) return;

      root.innerHTML = `<iframe
        src="https://www.youtube-nocookie.com/embed/${id}?autoplay=1"
        title="YouTube video player"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
        class="aspect-video w-full"
      ></iframe>`;
    });
  });
</script>
