<div
  id="cookie-notice"
  class="fixed bottom-0 left-0 right-0 z-50 px-4 py-4"
  role="region"
  aria-label="Aviso de cookies"
  hidden
>
  <div class="surface mx-auto flex max-w-screen-xl flex-col gap-3 rounded-lg p-4 text-gray-700 shadow-lg sm:flex-row sm:items-center sm:justify-between" role="alert">
    <p class="text-sm leading-6">
      Utilizamos cookies essenciais e tecnologias semelhantes de acordo com a nossa
      <a class="font-semibold text-primary-700 underline underline-offset-4 hover:text-primary-800" href="/politica-de-privacidade">Política de Privacidade</a>
      e, ao continuar navegando, você concorda com estas condições.
    </p>
    <button id="cookie-notice-ok" class="btn-primary inline-flex min-w-24 justify-center rounded-lg px-5 py-2.5 text-sm font-semibold focus:outline-none focus:ring-4 focus:ring-primary-200">
      OK
    </button>
  </div>
</div>

<script>
  const storageKey = "blk_cookie_notice_v1";
  const notice = document.getElementById("cookie-notice");
  const ok = document.getElementById("cookie-notice-ok");

  function noticeDismissed() {
    try {
      return localStorage.getItem(storageKey) === "dismissed";
    } catch {
      return false;
    }
  }

  function rememberDismissal() {
    try {
      localStorage.setItem(storageKey, "dismissed");
    } catch {
      return;
    }
  }

  if (!noticeDismissed() && notice) {
    notice.hidden = false;
  }

  ok?.addEventListener("click", () => {
    rememberDismissal();
    if (notice) notice.hidden = true;
  });
</script>
