---
import { buildWhatsAppUrl } from "../lib/whatsapp";
import { getWhatsAppNumber } from "../lib/contact";
import BrandIcon from "./BrandIcon.astro";

type Props = {
  service?: string | null;
  city?: string | null;
  location?: string | null;
  approximateAreaOrPerimeter?: string | null;
  objective?: string | null;
  deadline?: string | null;
  desiredDeliverable?: string | null;
  selectedCluster?: string | null;
  ctaLocation?: string | null;
  label?: string;
  className?: string;
};

const {
  service = null,
  city = null,
  location = null,
  approximateAreaOrPerimeter = null,
  objective = null,
  deadline = null,
  desiredDeliverable = null,
  selectedCluster = null,
  ctaLocation = null,
  label = "Chamar no WhatsApp",
  className = "inline-flex items-center justify-center rounded-lg px-5 py-3 font-semibold"
} = Astro.props as Props;

const number = getWhatsAppNumber();
const href = buildWhatsAppUrl(number, {
  service,
  city,
  location,
  approximateAreaOrPerimeter,
  objective,
  deadline,
  desiredDeliverable,
  selectedCluster,
  ctaLocation
});
---

<a
  data-testid="whatsapp-cta"
  data-whatsapp-link
  data-whatsapp-number={number}
  data-service={service ?? ""}
  data-city={city ?? ""}
  data-location={location ?? ""}
  data-approximate-area-or-perimeter={approximateAreaOrPerimeter ?? ""}
  data-objective={objective ?? ""}
  data-deadline={deadline ?? ""}
  data-desired-deliverable={desiredDeliverable ?? ""}
  data-selected-cluster={selectedCluster ?? ""}
  data-cta-location={ctaLocation ?? ""}
  class={className}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  <span class="inline-flex items-center justify-center gap-2">
    <span aria-hidden="true" class="inline-flex h-4 w-4">
      <BrandIcon name="whatsapp" class="h-4 w-4" />
    </span>
    <span>{label}</span>
  </span>
</a>
