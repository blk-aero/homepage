---
import "../styles/global.css";
import faviconPng from "../assets/brand/favicon.png";
import footerLogoInline from "../assets/brand/logo_inline_grey_fulltext_aero_nobackground.svg";
import logoInline from "../assets/brand/logo_inline_grey_halftext_aero_nobackground.svg";
import BrandIcon from "../components/BrandIcon.astro";
import GtmHead from "../components/GtmHead.astro";
import SeoHead from "../components/SeoHead.astro";
import SimpleCookieNotice from "../components/SimpleCookieNotice.astro";
import { buildDefaultWhatsAppUrl, getWhatsAppNumber } from "../lib/contact";
import { isBrandIconName } from "../lib/brand-icons";
import { getSiteConfig } from "../lib/site-config";

type Props = {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown> | null;
};

const {
  title,
  description = null,
  canonicalPath = Astro.url.pathname,
  jsonLd = null
} = Astro.props as Props;

const siteConfig = await getSiteConfig();
const pageDescription = description ?? siteConfig.meta.default_description;
const whatsAppNumber = getWhatsAppNumber();
const navWhatsAppHref = buildDefaultWhatsAppUrl({ ctaLocation: "nav" });
const footerWhatsAppHref = buildDefaultWhatsAppUrl({ ctaLocation: "footer" });
const navLinks = siteConfig.navigation.primary_links;
const currentYear = new Date().getFullYear();
const legalEntity = "BLK Gestão Empresarial Ltda. (CNPJ: 37.814.104-0001/40)";
const isExternalHref = (href: string) => /^https?:\/\//.test(href);
const footerColumns = [
  ...siteConfig.footer.link_columns.slice(0, 1),
  {
    title: "Contato",
    links: [
      { label: siteConfig.contact.phone_display, href: footerWhatsAppHref },
      { label: siteConfig.contact.email, href: `mailto:${siteConfig.contact.email}` }
    ]
  },
  ...siteConfig.footer.link_columns.slice(1)
];
const footerSocialLinks = siteConfig.footer.social_links.map((social) => {
  if (!isBrandIconName(social.icon)) {
    throw new Error(`Unsupported footer brand icon: ${social.icon}`);
  }
  return { ...social, icon: social.icon };
});
const logoInlineSrc = typeof logoInline === "string" ? logoInline : logoInline.src;
const footerLogoInlineSrc = typeof footerLogoInline === "string" ? footerLogoInline : footerLogoInline.src;
const faviconSrc = typeof faviconPng === "string" ? faviconPng : faviconPng.src;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <!-- [A/B Testing Entry Point] Future A/B testing or optimization scripts (e.g., VWO, Optimizely) go here -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={faviconSrc} />
    <link rel="apple-touch-icon" href={faviconSrc} />
    <SeoHead title={title} description={pageDescription} canonicalPath={canonicalPath} jsonLd={jsonLd} />
    <slot name="head" />
    <GtmHead />
  </head>
  <body class="min-h-screen">
    <header class="surface sticky top-0 z-40">
      <nav class="mx-auto flex max-w-screen-xl flex-wrap items-center justify-between p-4" aria-label="Navegação principal">
        <a class="flex items-center space-x-3 rtl:space-x-reverse" href="/">
          <img
            src={logoInlineSrc}
            alt={siteConfig.meta.brand_name}
            width="157"
            height="35"
            class="h-7 w-auto"
            loading="eager"
            decoding="async"
          />
        </a>
        <div class="order-2 flex items-center gap-2 md:order-3">
          <a
            class="btn-primary inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold"
            href={navWhatsAppHref}
            target="_blank"
            rel="noopener noreferrer"
            data-testid="nav-whatsapp-cta"
            data-whatsapp-link
            data-whatsapp-number={whatsAppNumber}
            data-cta-location="nav"
            aria-label="WhatsApp"
          >
            <span aria-hidden="true" class="inline-flex h-4 w-4">
              <BrandIcon name="whatsapp" class="h-4 w-4" />
            </span>
            <span>WhatsApp</span>
          </a>
          <button
            data-collapse-toggle="main-nav-menu"
            type="button"
            class="inline-flex h-10 w-10 items-center justify-center rounded-lg p-2 text-sm text-gray-700 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 md:hidden"
            aria-controls="main-nav-menu"
            aria-expanded="false"
          >
            <span class="sr-only">Abrir menu</span>
            <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 17 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15" />
            </svg>
          </button>
        </div>
        <div id="main-nav-menu" class="order-3 hidden w-full md:order-2 md:block md:w-auto">
          <ul class="mt-4 flex flex-col rounded-lg border border-gray-100 bg-gray-50 p-4 text-sm font-medium text-gray-700 md:mt-0 md:flex-row md:items-center md:space-x-8 md:border-0 md:bg-white md:p-0">
            {navLinks.map((link) => {
              const external = /^https?:\/\//.test(link.href);
              return (
                <li>
                  <a
                    class="block rounded-sm px-3 py-2 hover:bg-gray-100 md:p-0 md:hover:bg-transparent md:hover:underline"
                    href={link.href}
                    target={external ? "_blank" : undefined}
                    rel={external ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </nav>
    </header>

    <main class="site-main py-8">
      <slot />
    </main>

    <footer class="mt-12 border-t border-gray-200 bg-gray-50">
      <div class="mx-auto w-full max-w-6xl px-4 py-8 lg:py-10">
        <div class="gap-10 md:flex md:justify-between">
          <div class="mb-8 max-w-sm md:mb-0">
            <a href="/" class="flex items-center">
              <img
                src={footerLogoInlineSrc}
                alt={siteConfig.meta.brand_name}
                width="375"
                height="35"
                class="h-8 w-auto"
                loading="lazy"
                decoding="async"
              />
            </a>
            <p class="mt-4 text-sm leading-6 text-gray-600">{siteConfig.contact.footer_summary}</p>
            <p class="mt-3 text-xs leading-5 text-gray-500">{siteConfig.contact.trust_certifications}</p>
          </div>
          <div class="grid grid-cols-2 gap-8 sm:gap-6">
            {footerColumns.map((column) => (
              <div>
                <h2 class="mb-5 text-sm font-semibold uppercase tracking-wide text-gray-900">{column.title}</h2>
                <ul class="space-y-3 text-sm font-medium text-gray-600">
                  {column.links.map((link) => {
                    const external = isExternalHref(link.href);
                    const whatsappContact = link.href.startsWith("https://wa.me/");
                    const emailContact = link.href.startsWith("mailto:");
                    return (
                      <li>
                        <a
                          class="hover:text-gray-950 hover:underline"
                          href={link.href}
                          target={external ? "_blank" : undefined}
                          rel={external ? "noopener noreferrer" : undefined}
                          data-whatsapp-link={whatsappContact ? "true" : undefined}
                          data-whatsapp-number={whatsappContact ? whatsAppNumber : undefined}
                          data-email-link={emailContact ? "true" : undefined}
                          data-email-address={emailContact ? siteConfig.contact.email : undefined}
                          data-cta-location={whatsappContact || emailContact ? "footer" : undefined}
                        >
                          {link.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
                {"note" in column && <p class="mt-4 text-sm text-gray-500">{column.note}</p>}
              </div>
            ))}
          </div>
        </div>
        <hr class="my-6 border-gray-200 lg:my-8" />
        <div class="sm:flex sm:items-center sm:justify-between">
          <span class="text-sm text-gray-600 sm:text-center">
            © {currentYear} {legalEntity}. Todos os direitos reservados.
          </span>
          <div class="mt-4 flex sm:mt-0 sm:justify-center">
            {footerSocialLinks.map((social) => (
              <a
                href={social.href}
                class="ml-5 text-gray-500 first:ml-0 hover:text-gray-950"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                title={social.label}
                data-social-link
                data-social-platform={social.label}
              >
                <BrandIcon name={social.icon} class="h-5 w-5" />
                <span class="sr-only">{social.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </footer>

    <SimpleCookieNotice />
    <script>
      import { initAccordions } from "flowbite/lib/esm/components/accordion";
      import { initCollapses } from "flowbite/lib/esm/components/collapse";

      initAccordions();
      initCollapses();
    </script>
    <script>
      import { mergeFirstTouchAttribution } from "../lib/attribution";
      import { buildWhatsAppUrl, selectSourceCodedWhatsAppGreeting } from "../lib/whatsapp";

      (function () {
        const storageKey = "blk_attribution_v1";
        const cookieKey = "blk_cookie_attribution_v1";
        const landingPageKey = "blk_landing_page_v1";
        const landingCookieKey = "blk_cookie_landing_page_v1";
        const keys = ["utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content", "gclid"];

        function getCookie(name) {
          const nameEQ = name + "=";
          const ca = document.cookie.split(";");
          for (let i = 0; i < ca.length; i++) {
            let c = ca[i];
            while (c.charAt(0) === " ") c = c.substring(1, c.length);
            if (c.indexOf(nameEQ) === 0) return decodeURIComponent(c.substring(nameEQ.length, c.length));
          }
          return null;
        }

        function setCookie(name, value, days) {
          let expires = "";
          if (days) {
            const date = new Date();
            date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
            expires = "; expires=" + date.toUTCString();
          }
          document.cookie = name + "=" + encodeURIComponent(value) + expires + "; path=/; SameSite=Lax; Secure";
        }

        function safeSessionStorageGet(key) {
          try {
            return sessionStorage.getItem(key);
          } catch (e) {
            return null;
          }
        }

        function safeSessionStorageSet(key, value) {
          try {
            sessionStorage.setItem(key, value);
          } catch (e) {
            // Ignore storage blocked errors
          }
        }

        function getLandingPage() {
          let lp = safeSessionStorageGet(landingPageKey);
          if (!lp) {
            lp = getCookie(landingCookieKey);
            if (lp) {
              safeSessionStorageSet(landingPageKey, lp);
            }
          }
          if (!lp) {
            lp = window.location.pathname;
            safeSessionStorageSet(landingPageKey, lp);
            setCookie(landingCookieKey, lp, 7);
          }
          return lp;
        }

        function getPreviousPage() {
          if (!document.referrer) return "";
          try {
            const referrerUrl = new URL(document.referrer);
            if (referrerUrl.origin !== window.location.origin) return "";
            return referrerUrl.pathname;
          } catch {
            return "";
          }
        }

        function readStored() {
          try {
            return JSON.parse(safeSessionStorageGet(storageKey) || "{}");
          } catch {
            return {};
          }
        }

        function readCurrentParams() {
          const params = new URLSearchParams(window.location.search);
          const out = {};
          keys.forEach((key) => {
            const value = params.get(key);
            if (value) out[key] = value;
          });
          return out;
        }

        function readAttribution() {
          let stored = readStored();

          if (Object.keys(stored).length === 0) {
            try {
              stored = JSON.parse(getCookie(cookieKey) || "{}");
            } catch {
              stored = {};
            }
            if (Object.keys(stored).length > 0) {
              safeSessionStorageSet(storageKey, JSON.stringify(stored));
            }
          }

          const current = readCurrentParams();
          const attribution = mergeFirstTouchAttribution(stored, current);

          if (Object.keys(attribution).length > 0) {
            safeSessionStorageSet(storageKey, JSON.stringify(attribution));
            setCookie(cookieKey, JSON.stringify(attribution), 7);
          }
          return attribution;
        }

        function anchorPayload(node) {
          return {
            service: node.dataset.service || "",
            city: node.dataset.city || "",
            location: node.dataset.location || "",
            approximateAreaOrPerimeter: node.dataset.approximateAreaOrPerimeter || "",
            objective: node.dataset.objective || "",
            deadline: node.dataset.deadline || "",
            desiredDeliverable: node.dataset.desiredDeliverable || "",
            selectedCluster: node.dataset.selectedCluster || "",
            ctaLocation: node.dataset.ctaLocation || ""
          };
        }

        function syncAnchor(node) {
          const payload = anchorPayload(node);
          const attribution = readAttribution();
          const payloadWithAttribution = { ...payload, attribution };
          const greeting = selectSourceCodedWhatsAppGreeting(payloadWithAttribution);
          node.href = buildWhatsAppUrl(node.dataset.whatsappNumber || "", payloadWithAttribution);
          node.dataset.whatsappGreetingId = greeting.id;
          return { payload, attribution, greeting };
        }

        document.querySelectorAll("[data-whatsapp-link]").forEach((node) => {
          if (!(node instanceof HTMLAnchorElement)) return;
          if (node.dataset.bound === "1") return;
          node.dataset.bound = "1";
          syncAnchor(node);

          node.addEventListener("click", () => {
            const { payload, attribution, greeting } = syncAnchor(node);
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: "whatsapp_click",
              event_timestamp: new Date().toISOString(),
              service: payload.service || undefined,
              city: payload.city || undefined,
              selected_cluster: payload.selectedCluster || undefined,
              cta_location: payload.ctaLocation || undefined,
              whatsapp_greeting_id: greeting.id,
              page_path: window.location.pathname,
              landing_page: getLandingPage(),
              previous_page: getPreviousPage(),
              ...attribution
            });
          });
        });

        function emailFromLink(node) {
          const href = node.getAttribute("href") || "";
          if (!href.toLowerCase().startsWith("mailto:")) return "";
          return decodeURIComponent(href.slice("mailto:".length).split("?")[0]);
        }

        document.querySelectorAll("[data-email-link], a[href^='mailto:']").forEach((node) => {
          if (!(node instanceof HTMLAnchorElement)) return;
          if (node.dataset.bound === "1") return;
          node.dataset.bound = "1";

          node.addEventListener("click", () => {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: "email_click",
              event_timestamp: new Date().toISOString(),
              email: node.dataset.emailAddress || emailFromLink(node) || undefined,
              cta_location: node.dataset.ctaLocation || undefined,
              page_path: window.location.pathname,
              landing_page: getLandingPage(),
              previous_page: getPreviousPage(),
              ...readAttribution()
            });
          });
        });

        document.querySelectorAll("[data-social-link]").forEach((node) => {
          if (!(node instanceof HTMLAnchorElement)) return;
          if (node.dataset.bound === "1") return;
          node.dataset.bound = "1";

          node.addEventListener("click", () => {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: "social_click",
              event_timestamp: new Date().toISOString(),
              social_platform: node.dataset.socialPlatform || undefined,
              outbound_url: node.href,
              page_path: window.location.pathname,
              landing_page: getLandingPage(),
              previous_page: getPreviousPage(),
              ...readAttribution()
            });
          });
        });

        document.querySelectorAll("[data-final-whatsapp-form]").forEach((form) => {
          if (!(form instanceof HTMLFormElement)) return;
          if (form.dataset.bound === "1") return;
          form.dataset.bound = "1";

          const submit = form.querySelector("[data-final-whatsapp-submit]");
          if (!(submit instanceof HTMLAnchorElement)) return;

          function payload() {
            const data = new FormData(form);
            return {
              location: String(data.get("location") || "").trim(),
              objective: String(data.get("objective") || "").trim(),
              ctaLocation: form.dataset.ctaLocation || ""
            };
          }

          function syncHref() {
            const attribution = readAttribution();
            const payloadWithAttribution = { ...payload(), attribution };
            const greeting = selectSourceCodedWhatsAppGreeting(payloadWithAttribution);
            submit.href = buildWhatsAppUrl(form.dataset.whatsappNumber || "", payloadWithAttribution);
            submit.dataset.whatsappGreetingId = greeting.id;
            return { attribution, greeting };
          }

          syncHref();
          form.addEventListener("input", syncHref);
          form.addEventListener("change", syncHref);
          form.addEventListener("submit", (event) => event.preventDefault());

          submit.addEventListener("click", () => {
            const currentPayload = payload();
            const { attribution, greeting } = syncHref();
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: "whatsapp_click",
              event_timestamp: new Date().toISOString(),
              page_path: window.location.pathname,
              landing_page: getLandingPage(),
              previous_page: getPreviousPage(),
              cta_location: currentPayload.ctaLocation || undefined,
              whatsapp_greeting_id: greeting.id,
              ...attribution
            });
          });
        });
        readAttribution();
        getLandingPage();
      })();
    </script>
  </body>
</html>
