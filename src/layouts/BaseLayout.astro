---
import "../styles/global.css";
import faviconPng from "../assets/brand/favicon.png";
import logoInline from "../assets/brand/logo_inline_grey_halftext_aero_nobackground.svg";
import AttributionCapture from "../components/AttributionCapture.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import GtmHead from "../components/GtmHead.astro";
import SeoHead from "../components/SeoHead.astro";
import { buildDefaultWhatsAppUrl, getWhatsAppNumber } from "../lib/contact";
import { getSiteConfig } from "../lib/site-config";

type Props = {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown> | null;
};

const {
  title,
  description = null,
  canonicalPath = Astro.url.pathname,
  jsonLd = null
} = Astro.props as Props;

const siteConfig = await getSiteConfig();
const pageDescription = description ?? siteConfig.meta.default_description;
const navWhatsAppHref = buildDefaultWhatsAppUrl({
  intro: siteConfig.contact.whatsapp.nav_intro
});
const footerWhatsAppHref = buildDefaultWhatsAppUrl({
  intro: siteConfig.contact.whatsapp.footer_intro
});
const navLinks = siteConfig.navigation.primary_links;
const currentYear = new Date().getFullYear();
const phoneHref = `tel:+${getWhatsAppNumber()}`;
const isExternalHref = (href: string) => /^https?:\/\//.test(href);
const footerColumns = [
  ...siteConfig.footer.link_columns.slice(0, 1),
  {
    title: "Contato",
    links: [
      { label: siteConfig.contact.phone_display, href: phoneHref },
      { label: siteConfig.contact.email, href: `mailto:${siteConfig.contact.email}` },
      { label: "WhatsApp", href: footerWhatsAppHref }
    ],
    note: `${siteConfig.contact.address_city}, ${siteConfig.contact.address_state}`
  },
  ...siteConfig.footer.link_columns.slice(1)
];
const socialIcons: Record<string, { viewBox: string; paths: string[] }> = {
  linkedin: {
    viewBox: "0 0 24 24",
    paths: [
      "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.049c.476-.9 1.637-1.852 3.369-1.852 3.602 0 4.267 2.37 4.267 5.455v6.288zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM7.114 20.452H3.558V9h3.556v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
    ]
  },
  youtube: {
    viewBox: "0 0 24 24",
    paths: [
      "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
    ]
  },
  facebook: {
    viewBox: "0 0 24 24",
    paths: [
      "M22.675 0h-21.35C.593 0 0 .593 0 1.326v21.348C0 23.407.593 24 1.325 24h11.495v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.464.099 2.797.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.312h3.587l-.467 3.622h-3.12V24h6.116c.73 0 1.324-.593 1.324-1.326V1.326C24 .593 23.407 0 22.675 0z"
    ]
  },
  instagram: {
    viewBox: "0 0 24 24",
    paths: [
      "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
    ]
  }
};
const logoInlineSrc = typeof logoInline === "string" ? logoInline : logoInline.src;
const faviconSrc = typeof faviconPng === "string" ? faviconPng : faviconPng.src;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={faviconSrc} />
    <link rel="apple-touch-icon" href={faviconSrc} />
    <SeoHead title={title} description={pageDescription} canonicalPath={canonicalPath} jsonLd={jsonLd} />
    <slot name="head" />
    <GtmHead />
  </head>
  <body class="min-h-screen">
    <header class="surface sticky top-0 z-40">
      <nav class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-3" aria-label="Navegacao principal">
        <a class="inline-flex items-center" href="/">
          <img
            src={logoInlineSrc}
            alt={siteConfig.meta.brand_name}
            class="h-8 w-auto md:h-9"
            loading="eager"
            decoding="async"
          />
        </a>
        <div class="order-2 flex items-center gap-2 md:order-3">
          <a
            class="btn-primary inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold"
            href={navWhatsAppHref}
            target="_blank"
            rel="noopener noreferrer"
            data-testid="nav-whatsapp-cta"
            aria-label="WhatsApp"
          >
            <span aria-hidden="true" class="inline-flex h-4 w-4">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.5 14.4c-.3-.2-1.9-.9-2.2-1-.3-.1-.5-.2-.7.2s-.8 1-.9 1.1c-.2.2-.3.2-.6.1s-1.3-.5-2.5-1.6c-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.4.1-.6l.5-.6c.2-.2.2-.3.3-.5.1-.2 0-.4 0-.6 0-.2-.7-1.7-1-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4s-1.1 1.1-1.1 2.7 1.2 3.2 1.4 3.4c.2.2 2.3 3.5 5.6 4.8.8.3 1.4.5 1.9.6.8.2 1.5.1 2 .1.6-.1 1.9-.8 2.1-1.6.3-.8.3-1.4.2-1.6 0-.1-.2-.2-.5-.3z"></path>
                <path d="M12 2C6.5 2 2 6.4 2 11.9c0 1.9.5 3.8 1.6 5.4L2 22l4.9-1.5c1.5.8 3.3 1.3 5.1 1.3 5.5 0 10-4.4 10-9.9S17.5 2 12 2zm0 18.1c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-2.9.9.9-2.8-.2-.3C4 15.2 3.5 13.6 3.5 12 3.5 7.3 7.3 3.5 12 3.5s8.5 3.8 8.5 8.5-3.8 8.1-8.5 8.1z"></path>
              </svg>
            </span>
            <span>WhatsApp</span>
          </a>
          <button
            data-collapse-toggle="main-nav-menu"
            type="button"
            class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-300 md:hidden"
            aria-controls="main-nav-menu"
            aria-expanded="false"
          >
            <span class="sr-only">Abrir menu</span>
            <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 17 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15" />
            </svg>
          </button>
        </div>
        <div id="main-nav-menu" class="order-3 hidden w-full md:order-2 md:block md:w-auto">
          <ul class="mt-2 flex flex-col gap-2 rounded-xl border border-gray-200 bg-white p-3 text-sm text-gray-700 md:mt-0 md:flex-row md:items-center md:gap-5 md:border-0 md:bg-transparent md:p-0">
            {navLinks.map((link) => {
              const external = /^https?:\/\//.test(link.href);
              return (
                <li>
                  <a
                    class="hover:underline"
                    href={link.href}
                    target={external ? "_blank" : undefined}
                    rel={external ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>

    <footer class="mt-12 border-t border-gray-200 bg-gray-50">
      <div class="mx-auto w-full max-w-6xl px-4 py-8 lg:py-10">
        <div class="gap-10 md:flex md:justify-between">
          <div class="mb-8 max-w-sm md:mb-0">
            <a href="/" class="flex items-center">
              <img
                src={logoInlineSrc}
                alt={siteConfig.meta.brand_name}
                class="h-8 w-auto"
                loading="lazy"
                decoding="async"
              />
            </a>
            <p class="mt-4 text-sm leading-6 text-gray-600">{siteConfig.contact.footer_summary}</p>
            <p class="mt-3 text-xs leading-5 text-gray-500">{siteConfig.contact.trust_certifications}</p>
          </div>
          <div class="grid grid-cols-2 gap-8 sm:gap-6">
            {footerColumns.map((column) => (
              <div>
                <h2 class="mb-5 text-sm font-semibold uppercase tracking-wide text-gray-900">{column.title}</h2>
                <ul class="space-y-3 text-sm font-medium text-gray-600">
                  {column.links.map((link) => {
                    const external = isExternalHref(link.href);
                    return (
                      <li>
                        <a
                          class="hover:text-gray-950 hover:underline"
                          href={link.href}
                          target={external ? "_blank" : undefined}
                          rel={external ? "noopener noreferrer" : undefined}
                        >
                          {link.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
                {"note" in column && <p class="mt-4 text-sm text-gray-500">{column.note}</p>}
              </div>
            ))}
          </div>
        </div>
        <hr class="my-6 border-gray-200 lg:my-8" />
        <div class="sm:flex sm:items-center sm:justify-between">
          <span class="text-sm text-gray-600 sm:text-center">
            © {currentYear} <a href="/" class="hover:underline">BLK Aero</a>. Todos os direitos reservados.
          </span>
          <div class="mt-4 flex sm:mt-0 sm:justify-center">
            {siteConfig.footer.social_links.map((social) => {
              const icon = socialIcons[social.icon];
              return (
                <a
                  href={social.href}
                  class="ml-5 text-gray-500 first:ml-0 hover:text-gray-950"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={social.label}
                  title={social.label}
                >
                  <svg class="h-5 w-5" aria-hidden="true" viewBox={icon.viewBox} fill="currentColor">
                    {icon.paths.map((path) => (
                      <path d={path}></path>
                    ))}
                  </svg>
                  <span class="sr-only">{social.label}</span>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </footer>

    <ConsentBanner />
    <AttributionCapture />
    <script is:inline>
      document.querySelectorAll("[data-collapse-toggle]").forEach((trigger) => {
        if (!(trigger instanceof HTMLElement)) return;
        const targetId = trigger.dataset.collapseToggle;
        if (!targetId) return;
        const target = document.getElementById(targetId);
        if (!target) return;

        trigger.addEventListener("click", (event) => {
          event.preventDefault();
          const hidden = target.classList.toggle("hidden");
          trigger.setAttribute("aria-expanded", String(!hidden));
        });
      });
    </script>
  </body>
</html>
