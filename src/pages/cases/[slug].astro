---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const cases = await getCollection("cases");
  return cases.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

type Props = {
  entry: CollectionEntry<"cases">;
};

const { entry } = Astro.props as Props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="surface rounded-2xl p-6">
    <h1 class="text-3xl font-bold">{entry.data.title}</h1>
    <p class="mt-3 text-sm">{entry.data.summary}</p>
    <p class="mt-4 text-sm"><strong>Servico:</strong> {entry.data.service_slug}</p>
    <p class="text-sm"><strong>Cidade:</strong> {entry.data.city_slug}</p>
    <div class="prose mt-5 max-w-none text-sm">
      <Content />
    </div>
  </article>
</BaseLayout>
