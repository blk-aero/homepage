---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import LeadMagnetCta from "../components/LeadMagnetCta.astro";
---

<BaseLayout title="BLK Aero - Topografia e Georreferenciamento" description="Topografia, georreferenciamento e viabilidade com base auditavel para decisoes tecnicas.">
  <Hero
    h1="Topografia e Georreferenciamento para Decisao sem Retrabalho"
    subheadline="Entregamos base geoespacial auditavel para reduzir risco, acelerar cronograma e melhorar a qualidade da decisao tecnica."
    primaryCtaLabel="Chamar no WhatsApp"
    primaryCtaHref="/servicos/georreferenciamento-de-imovel-rural"
    secondaryCtaLabel="Baixar guia"
    secondaryCtaHref="/ofertas/guia-georreferenciamento"
  />

  <section class="mt-6 grid gap-4 md:grid-cols-3">
    <a class="surface rounded-xl p-4" href="/servicos/levantamento-planialtimetrico-para-projeto-arquitetonico">
      <h2 class="text-lg font-semibold">Levantamento planialtimetrico</h2>
      <p class="mt-2 text-sm">Base precisa para projeto arquitetonico com menor risco de retrabalho.</p>
    </a>
    <a class="surface rounded-xl p-4" href="/servicos/georreferenciamento-de-imovel-rural">
      <h2 class="text-lg font-semibold">Georreferenciamento rural</h2>
      <p class="mt-2 text-sm">Peças tecnicas com foco em regularizacao e seguranca juridica.</p>
    </a>
    <a class="surface rounded-xl p-4" href="/servicos/viabilidade-de-terraplenagem">
      <h2 class="text-lg font-semibold">Viabilidade de terraplenagem</h2>
      <p class="mt-2 text-sm">Cenarios de volume para reduzir surpresa financeira na obra.</p>
    </a>
  </section>

  <LeadMagnetCta href="/ofertas/guia-georreferenciamento" />
</BaseLayout>
