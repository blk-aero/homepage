---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeFinalWhatsAppComposer from "../components/HomeFinalWhatsAppComposer.astro";
import HomeHeroShowcase from "../components/HomeHeroShowcase.astro";
import WhatsAppCTA from "../components/WhatsAppCTA.astro";
import platformImage from "../assets/homepage/platform/blk-hub.webp";
import { Image } from "astro:assets";
import { getSiteConfig } from "../lib/site-config";
import { homepageContent } from "../lib/homepage-content";

const siteConfig = await getSiteConfig();
const { meta } = siteConfig;
---

<BaseLayout title={meta.home_title} description={meta.home_description}>
  <HomeHeroShowcase
    h1={homepageContent.hero.title}
    subheadline={homepageContent.hero.subheadline}
    primaryCtaLabel={homepageContent.hero.primaryCtaLabel}
    slides={homepageContent.hero.slides}
  />

  <section data-testid="section-compact-proof" class="surface mt-6 rounded-xl p-6">
    <h2 class="text-xl font-semibold">{homepageContent.proofBand.credentialsTitle}</h2>
    <ul class="mt-3 flex flex-wrap gap-2 text-sm text-gray-700 dark:text-gray-300">
      {homepageContent.proofBand.credentials.map((item) => (
        <li class="rounded-md border border-gray-200 px-3 py-1 grayscale dark:border-gray-800">
          {item}
        </li>
      ))}
    </ul>
    <h3 class="mt-5 text-lg font-semibold">{homepageContent.proofBand.clientProjectsTitle}</h3>
    <ul class="mt-3 flex flex-wrap gap-2 text-sm text-gray-700 dark:text-gray-300">
      {homepageContent.proofBand.clientProjects.map((item) => (
        <li class="rounded-md border border-gray-200 px-3 py-1 grayscale dark:border-gray-800">
          {item}
        </li>
      ))}
    </ul>
  </section>

  <section data-testid="section-triage-cards" class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4 md:p-6">
    <div data-testid="triage-inner-panel" class="rounded-lg border border-gray-200 bg-white p-6 md:p-8">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <h2 class="text-3xl font-semibold leading-tight text-gray-950">
            {homepageContent.triageCards.heading}
          </h2>
          <p class="mt-4 text-base leading-7 text-gray-700">{homepageContent.triageCards.intro}</p>
        </div>
        <WhatsAppCTA
          label={homepageContent.hero.primaryCtaLabel}
          ctaLocation="triage-section"
          className="btn-primary inline-flex rounded-lg px-5 py-3 text-sm font-semibold"
        />
      </div>
      <div class="mt-6 grid gap-3 md:grid-cols-5">
        {homepageContent.triageCards.cards.map((card) => (
          <article class="flex min-h-full flex-col rounded-lg border border-gray-200 bg-gray-50 p-4">
            <h3 class="text-base font-semibold leading-snug text-gray-950">{card.title}</h3>
            <p class="mt-3 text-sm leading-6 text-gray-700">{card.summary}</p>
            <a class="mt-auto pt-4 text-sm font-semibold text-primary-800 hover:underline" href={card.detailPath}>
              <span>Ver detalhes</span>
              <span class="sr-only">: {card.title}</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section data-testid="section-deliverables" class="mt-6 rounded-xl border border-gray-200 bg-white p-6 md:p-8">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary-700">
        {homepageContent.deliverables.eyebrow}
      </p>
      <h2 class="mt-3 text-3xl font-semibold leading-tight text-gray-950">{homepageContent.deliverables.title}</h2>
      <p class="mt-4 text-base leading-7 text-gray-700">{homepageContent.deliverables.intro}</p>
    </div>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {homepageContent.deliverables.groups.map((group) => (
        <article class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-sm font-semibold text-primary-800">{group.trigger}</p>
          <h3 class="mt-3 text-xl font-semibold text-gray-950">{group.title}</h3>
          <p class="mt-3 text-sm leading-6 text-gray-700">{group.description}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {group.tags.map((tag) => (
              <span class="rounded-full bg-primary-100 px-3 py-1 text-xs font-semibold text-primary-950 ring-1 ring-primary-200">
                {tag === "as-built" ? <em>{tag}</em> : tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section data-testid="section-visualization-platform" class="full-bleed mt-6 border-y border-gray-200 bg-white px-4 py-10">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-primary-700">
          {homepageContent.visualizationPlatform.eyebrow}
        </p>
        <h2 class="mt-3 text-3xl font-semibold leading-tight text-gray-950">
          {homepageContent.visualizationPlatform.headline}
        </h2>
        <p class="mt-4 text-base leading-7 text-gray-700">{homepageContent.visualizationPlatform.description}</p>
        <dl class="mt-6 grid gap-4 sm:grid-cols-3">
          {homepageContent.visualizationPlatform.highlights.map((highlight) => (
            <div class="border-l-4 border-primary-600 pl-3">
              <dt class="sr-only">Destaque</dt>
              <dd class="text-sm font-semibold leading-6 text-gray-800">{highlight}</dd>
            </div>
          ))}
        </dl>
      </div>
      <div class="rounded-xl border border-gray-200 bg-gray-50 p-3 shadow-sm">
        <Image
          src={platformImage}
          alt={homepageContent.visualizationPlatform.imageAlt}
          class="rounded-lg border border-gray-200 object-cover object-left-top"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section data-testid="section-technical-confidence" class="mt-6 rounded-xl border border-gray-200 bg-white p-6 md:p-8">
    <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-semibold leading-tight text-gray-950">{homepageContent.technicalConfidence.title}</h2>
        <p class="mt-4 text-base leading-7 text-gray-700">{homepageContent.technicalConfidence.framing}</p>
      </div>
      <a
        class="inline-flex shrink-0 rounded-full bg-primary-100 px-4 py-2 text-sm font-semibold text-primary-950 ring-1 ring-primary-200"
        href={homepageContent.technicalConfidence.trustBadge.href}
        target="_blank"
        rel="noopener noreferrer"
      >
        {homepageContent.technicalConfidence.trustBadge.label}
      </a>
    </div>
    <ol class="mt-8 items-start sm:flex">
      {homepageContent.technicalConfidence.steps.map((step, index) => (
        <li class="relative mb-8 sm:mb-0 sm:flex-1">
          <div class="flex items-center">
            <div class="z-10 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary-700 text-sm font-semibold text-white ring-8 ring-white">
              {index + 1}
            </div>
            <div class="hidden h-0.5 w-full bg-gray-200 sm:flex"></div>
          </div>
          <div class="mt-3 pe-4">
            <h3 class="text-base font-semibold text-gray-950">{step.title}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-700">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section data-testid="section-portfolio" class="mt-6 rounded-xl border border-gray-200 bg-white p-6 md:p-8">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary-700">{homepageContent.portfolio.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-semibold leading-tight text-gray-950">{homepageContent.portfolio.title}</h2>
      <p class="mt-4 text-base leading-7 text-gray-700">{homepageContent.portfolio.intro}</p>
    </div>
    <div class="mt-6 grid gap-4 md:grid-cols-5">
      {homepageContent.portfolio.cards.map((card, index) => (
        <article class="flex h-full flex-col rounded-lg border border-gray-200 bg-gray-50 p-4">
          <div data-testid="portfolio-skeleton" class="flex aspect-[16/10] flex-col justify-between rounded-md border border-gray-200 bg-white p-4">
            <div class="space-y-2">
              <div class="h-2 w-1/2 rounded-full bg-gray-200"></div>
              <div class:list={["h-2 rounded-full bg-gray-100", index % 2 === 0 ? "w-3/4" : "w-2/3"]}></div>
            </div>
            <p class="text-xl font-semibold text-primary-800">{card.artifact}</p>
          </div>
          <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-primary-700">{card.cluster}</p>
          <h3 class="mt-2 text-lg font-semibold leading-snug text-gray-950">{card.title}</h3>
          <p class="mt-3 flex-1 text-sm leading-6 text-gray-700">{card.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {card.tags.map((tag) => (
              <span class="rounded-full border border-gray-200 bg-white px-2.5 py-1 text-xs font-semibold text-gray-700">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section data-testid="section-faq" class="mt-6 rounded-xl border border-gray-200 bg-white p-6 md:p-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-3xl font-semibold leading-tight text-gray-950">{homepageContent.faq.title}</h2>
      <div id="homepage-faq" data-accordion="collapse" class="mt-6 border-t border-gray-200">
        {homepageContent.faq.items.map((item, index) => (
          <div class="border-b border-gray-200">
            <h3 id={`homepage-faq-heading-${index}`}>
              <button
                type="button"
                class="flex w-full items-center justify-between gap-4 py-5 text-left text-base font-semibold text-gray-950"
                data-accordion-target={`#homepage-faq-body-${index}`}
                aria-expanded={index === 0 ? "true" : "false"}
                aria-controls={`homepage-faq-body-${index}`}
              >
                <span>{item.question}</span>
                <svg data-accordion-icon class="h-3 w-3 shrink-0 rotate-180" aria-hidden="true" viewBox="0 0 10 6" fill="none">
                  <path d="M9 5 5 1 1 5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                </svg>
              </button>
            </h3>
            <div id={`homepage-faq-body-${index}`} class={index === 0 ? "" : "hidden"} aria-labelledby={`homepage-faq-heading-${index}`}>
              <p class="pb-5 text-sm leading-6 text-gray-700">{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <HomeFinalWhatsAppComposer content={homepageContent.finalCta} primaryCtaLabel={homepageContent.hero.primaryCtaLabel} />
</BaseLayout>
