---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHeroShowcase from "../components/HomeHeroShowcase.astro";
import LeadMagnetCta from "../components/LeadMagnetCta.astro";
import { getSiteConfig } from "../lib/site-config";

const siteConfig = await getSiteConfig();
const { home, meta } = siteConfig;
---

<BaseLayout title={meta.home_title} description={meta.home_description}>
  <HomeHeroShowcase
    h1={home.hero.h1}
    subheadline={home.hero.subheadline}
    primaryCtaLabel={home.hero.primary_cta_label}
    primaryCtaHref={home.hero.primary_cta_href}
    secondaryCtaLabel={home.hero.secondary_cta_label}
    secondaryCtaHref={home.hero.secondary_cta_href}
  />

  <section class="mt-6 grid gap-4 md:grid-cols-3">
    {home.service_cards.map((card) => (
      <a class="surface rounded-xl p-4" href={card.href}>
        <h2 class="text-lg font-semibold">{card.title}</h2>
        <p class="mt-2 text-sm">{card.description}</p>
      </a>
    ))}
  </section>

  <LeadMagnetCta
    title={home.lead_magnet.title}
    description={home.lead_magnet.description}
    href={home.lead_magnet.href}
    label={home.lead_magnet.label}
  />
</BaseLayout>
