---
import { getCollection, type CollectionEntry } from "astro:content";
import rolloutData from "../../../../data/rollout-control.json";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ComparisonTable from "../../../components/ComparisonTable.astro";
import Hero from "../../../components/Hero.astro";
import LeadMagnetCta from "../../../components/LeadMagnetCta.astro";
import WhatsAppCTA from "../../../components/WhatsAppCTA.astro";
import { parseRolloutControl, isCityActive, isServiceActive } from "../../../lib/rollout";
import { buildServiceCityPairs } from "../../../lib/routes";

export async function getStaticPaths() {
  const control = parseRolloutControl(rolloutData);
  const services = await getCollection("services");
  const cities = await getCollection("cities");

  const activeServiceEntries = services.filter((entry) => isServiceActive(control, entry.slug));
  const activeCityEntries = cities.filter((entry) => isCityActive(control, entry.slug));

  const pairings = buildServiceCityPairs(
    activeServiceEntries.map((entry) => entry.slug),
    activeCityEntries.map((entry) => entry.slug),
    control.blocked_combinations ?? []
  );

  const servicesBySlug = new Map(activeServiceEntries.map((entry) => [entry.slug, entry]));
  const citiesBySlug = new Map(activeCityEntries.map((entry) => [entry.slug, entry]));

  return pairings
    .map((pair) => {
      const serviceEntry = servicesBySlug.get(pair.service);
      const cityEntry = citiesBySlug.get(pair.city);
      if (!serviceEntry || !cityEntry) return null;

      return {
        params: { service: pair.service, city: pair.city },
        props: { serviceEntry, cityEntry }
      };
    })
    .filter(Boolean);
}

type Props = {
  serviceEntry: CollectionEntry<"services">;
  cityEntry: CollectionEntry<"cities">;
};

const { serviceEntry, cityEntry } = Astro.props as Props;
const comparisonRows = serviceEntry.data.competitor_comparison ?? [];
---

<BaseLayout
  title={`${serviceEntry.data.title} em ${cityEntry.data.name}`}
  description={serviceEntry.data.summary_bluf}
>
  <Hero
    h1={`${serviceEntry.data.title} em ${cityEntry.data.name}`}
    subheadline={serviceEntry.data.summary_bluf}
    primaryCtaLabel="Chamar no WhatsApp"
    primaryCtaHref="#primary-whatsapp"
    secondaryCtaLabel="Baixar guia"
    secondaryCtaHref={serviceEntry.data.lead_magnet_href ?? "/ofertas/guia-georreferenciamento"}
    guaranteeText={serviceEntry.data.guarantee ?? null}
    priceAnchor={serviceEntry.data.price_anchor}
  />

  <section class="surface mt-6 rounded-2xl p-5">
    <h2 class="text-xl font-semibold">Cobertura em {cityEntry.data.name}</h2>
    <p class="mt-2 text-sm">
      Atendemos bairros como {cityEntry.data.neighborhoods.slice(0, 3).join(", ")} com planejamento de campo e entrega auditavel.
    </p>
    <dl id="specs" class="mt-4 space-y-3">
      {serviceEntry.data.specifications.map((spec) => (
        <div>
          <dt class="text-sm font-semibold">{spec.key}</dt>
          <dd class="text-sm">{spec.value}</dd>
        </div>
      ))}
    </dl>
  </section>

  {comparisonRows.length > 0 && <ComparisonTable rows={comparisonRows} />}

  <LeadMagnetCta href={serviceEntry.data.lead_magnet_href ?? "/ofertas/guia-georreferenciamento"} />

  <section class="surface mt-6 rounded-2xl p-5" id="primary-whatsapp">
    <h2 class="text-xl font-semibold">Atendimento para {cityEntry.data.name}</h2>
    <div class="mt-4">
      <WhatsAppCTA service={serviceEntry.slug} city={cityEntry.slug} />
    </div>
  </section>
</BaseLayout>
