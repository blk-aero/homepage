---
import BaseLayout from "../layouts/BaseLayout.astro";

const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "BLK Aero",
  taxID: "00.000.000/0001-00",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Sao Jose dos Campos",
    addressRegion: "SP",
    addressCountry: "BR"
  }
};
---

<BaseLayout title="Sobre a BLK Aero" description="Entidade tecnica com foco em base geoespacial auditavel.">
  <section class="surface rounded-2xl p-6">
    <h1 class="text-3xl font-bold">Sobre a BLK Aero</h1>
    <p class="mt-3 text-sm">Somos uma operacao tecnica focada em transformar captura de campo em decisao auditavel.</p>
  </section>

  <section class="surface mt-6 rounded-2xl p-6">
    <h2 class="text-xl font-semibold">Dados de confianca</h2>
    <ul class="mt-3 space-y-2 text-sm">
      <li><strong>CNPJ:</strong> 00.000.000/0001-00</li>
      <li><strong>Endereco:</strong> Sao Jose dos Campos, SP</li>
      <li><strong>Certificacoes:</strong> Piloto remoto homologado e rotina de controle de qualidade interno</li>
    </ul>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(organization)}></script>
</BaseLayout>
