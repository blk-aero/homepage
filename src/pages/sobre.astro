---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteConfig } from "../lib/site-config";

const siteConfig = await getSiteConfig();
const { meta, contact } = siteConfig;

const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: meta.legal_name,
  ...(contact.cnpj ? { taxID: contact.cnpj } : {}),
  address: {
    "@type": "PostalAddress",
    addressLocality: contact.address_city,
    addressRegion: contact.address_state,
    addressCountry: contact.address_country
  }
};
---

<BaseLayout title={meta.about_title} description={meta.about_description}>
  <section class="surface rounded-2xl p-6">
    <h1 class="text-3xl font-bold">{meta.about_title}</h1>
    <p class="mt-3 text-sm">{contact.about_intro}</p>
  </section>

  <section class="surface mt-6 rounded-2xl p-6">
    <h2 class="text-xl font-semibold">{contact.about_trust_title}</h2>
    <ul class="mt-3 space-y-2 text-sm">
      {contact.cnpj && <li><strong>CNPJ:</strong> {contact.cnpj}</li>}
      <li><strong>Endereco:</strong> {contact.address_city}, {contact.address_state}</li>
      <li><strong>Certificacoes:</strong> {contact.about_certifications}</li>
    </ul>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(organization)}></script>
</BaseLayout>
